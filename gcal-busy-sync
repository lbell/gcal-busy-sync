/**
 * One-way sync source calendars into an aggregate "free/busy" calendar.
 * Includes all-day and recurring events.
 * Adds a buffer before/after each timed event.
 * Throttled to avoid Google Apps Script quota limits.
 */
function syncCalendars() {

  // ╔══════════════════════════════════════════════════════════════╗
  // ║                      EDIT THIS SECTION                       ║
  // ╚══════════════════════════════════════════════════════════════╝

  // -- Source calendars --
  // Add the IDs of every calendar you want to pull into the combined calendar.
  // Find a calendar's ID in Google Calendar → Settings → [calendar name] → Calendar ID.
  const SOURCE_CAL_IDS = [
    'example1@gmail.com',       // e.g. Personal calendar
    'example2@group.calendar.google.com'  // e.g. Work calendar
  ];

  // -- Target calendar --
  // The ID of the combined "free/busy" calendar you want to sync into.
  const TARGET_CAL_ID = 'your-target-calendar-id@group.calendar.google.com';

  // -- How far ahead to sync (in days) --
  const LOOKAHEAD_DAYS = 365;

  // -- Buffer time around events (in minutes) --
  // Adds padding before and after each timed event (not all-day events).
  // Set to 0 for no buffer.
  const BUFFER_MINUTES = 15;

  // -- Show full event info or just "Busy"? --
  // true  → copies the original event title and description
  // false → shows "Busy" as the title (hides event details from viewers)
  const SHOW_FULL_EVENT_INFO = false;

  // -- Append the source calendar name to each event title? --
  // true  → e.g. "Team Lunch [Work]" or "Busy [Personal]"
  // false → e.g. "Team Lunch" or "Busy"
  const APPEND_CALENDAR_NAME = false;

  // ╔══════════════════════════════════════════════════════════════╗
  // ║              🚫  DO NOT EDIT BELOW THIS LINE                 ║
  // ╚══════════════════════════════════════════════════════════════╝

  const THROTTLE_MS = 200;

  const now = new Date();
  const end = new Date();
  end.setDate(now.getDate() + LOOKAHEAD_DAYS);

  const targetCal = CalendarApp.getCalendarById(TARGET_CAL_ID);
  if (!targetCal) throw new Error('Target calendar not found or no permission.');

  const targetEvents = targetCal.getEvents(now, end);
  const targetMap = new Map();
  for (let event of targetEvents) {
    const desc = event.getDescription();
    const match = desc.match(/SRCID:([^\s]+)/);
    if (match) targetMap.set(match[1], event);
  }

  const seenIds = new Set();

  for (let calId of SOURCE_CAL_IDS) {
    const cal = CalendarApp.getCalendarById(calId);
    if (!cal) continue;

    const calName = cal.getName();
    const events = cal.getEvents(now, end);

    for (let e of events) {
      const srcId = `${calId}::${e.getId()}::${e.getStartTime().getTime()}`;
      if (seenIds.has(srcId)) continue;
      seenIds.add(srcId);
      createOrUpdateEvent(
        e, srcId, targetCal, targetMap,
        THROTTLE_MS, BUFFER_MINUTES,
        SHOW_FULL_EVENT_INFO, APPEND_CALENDAR_NAME, calName
      );
    }
  }

  for (let [srcId, evt] of targetMap.entries()) {
    if (!seenIds.has(srcId)) {
      evt.deleteEvent();
      Utilities.sleep(THROTTLE_MS);
    }
  }

  const pastEvents = targetCal.getEvents(new Date(0), now);
  for (let e of pastEvents) {
    e.deleteEvent();
    Utilities.sleep(THROTTLE_MS);
  }

  Logger.log(`Sync complete: ${seenIds.size} events synced.`);
}

function createOrUpdateEvent(
  event, srcId, targetCal, targetMap,
  throttleMs, bufferMinutes,
  showFullInfo, appendCalName, calName
) {
  const start = event.getStartTime();
  const end = event.getEndTime();
  const isAllDay = event.isAllDayEvent();

  let bufferedStart = start;
  let bufferedEnd = end;

  if (!isAllDay) {
    const bufferMs = bufferMinutes * 60 * 1000;
    bufferedStart = new Date(start.getTime() - bufferMs);
    bufferedEnd = new Date(end.getTime() + bufferMs);
  }

  let title = showFullInfo ? (event.getTitle() || 'Busy') : 'Busy';
  if (appendCalName && calName) title = `${title} [${calName}]`;

  let description = `SRCID:${srcId}`;
  if (showFullInfo) {
    const originalDesc = event.getDescription();
    if (originalDesc) description = `${originalDesc}\n\n${description}`;
  }

  const existing = targetMap.get(srcId);
  if (existing) {
    const timingChanged =
      existing.getStartTime().getTime() !== bufferedStart.getTime() ||
      existing.getEndTime().getTime() !== bufferedEnd.getTime();
    const titleChanged = existing.getTitle() !== title;

    if (timingChanged) existing.setTime(bufferedStart, bufferedEnd);
    if (titleChanged) existing.setTitle(title);
    if (timingChanged || titleChanged) Utilities.sleep(throttleMs);
  } else {
    targetCal.createEvent(title, bufferedStart, bufferedEnd, {
      description: description,
      transparency: 'opaque'
    });
    Utilities.sleep(throttleMs);
  }
}